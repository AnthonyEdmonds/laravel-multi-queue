{
    "name": "anthonyedmonds/laravel-multi-queue",
    "description": "Have a Laravel job worker listen to multiple queues instead of just one!",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Anthony Edmonds",
            "email": "contact@anthonyedmonds.me",
            "homepage": "https://anthonyedmonds.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8",
        "laravel/framework": "^13"
    },
    "autoload": {
        "psr-4": {
            "AnthonyEdmonds\\LaravelMultiQueue\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AnthonyEdmonds\\LaravelMultiQueue\\MultiQueueServiceProvider"
            ]
        }
    }
}
